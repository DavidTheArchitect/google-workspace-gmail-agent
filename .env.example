# Safe first-run configuration. Setup-Gmail-Agent.cmd copies this file to .env.
# Plan-only is the built-in default. Uncomment to make it explicit.
# CA_RUN_MODE=plan_only
CA_CONSOLE_PORT=8765
CA_CONSOLE_OPEN_BROWSER=true
# The native default is loopback. Docker supplies 0.0.0.0 only inside its host-loopback mapping.
# CA_CONSOLE_BIND_HOST=127.0.0.1

# Optional natural-language planning. The deterministic form works without Ollama.
CA_OLLAMA_BASE_URL=http://localhost:11434/v1
CA_OLLAMA_MODEL=gemma4:12b
# Use a different locally installed vision-capable model here if this Gemma build cannot accept images.
CA_BROWSER_MODEL=gemma4:12b
CA_PERSONA_TEMPERATURE=0.9
CA_GROUP_CHAT_MAX_ROUNDS=6
CA_BROWSER_AGENT_MAX_STEPS=40
CA_BROWSER_CANDIDATE_LIMIT=80
CA_GMAIL_COMPLIANCE_URL=https://admin.google.com/ac/apps/gmail/compliance

# Live mode also requires accepted UI evidence and an installed live runner.
# CA_EXPECTED_ADMIN_EMAIL=admin@example.com
# CA_EXPECTED_WORKSPACE_DOMAIN=example.com
