# Docker Compose starts the Reflex Mission Control application, Ollama, and gemma4:12b together.
# It works with no .env file and does not require host Node, Python, uv, or Ollama. Uncomment these
# Compose-only overrides to select another internal endpoint or model. Application startup pulls a
# missing model once.
# OLLAMA_BASE_URL=http://ollama:11434/v1
# OLLAMA_MODEL=gemma4:12b
# LLM_REQUEST_TIMEOUT_SECONDS=600
# GROUP_CHAT_TIMEOUT_SECONDS=1800

# Safe native-development configuration. Setup-Gmail-Agent.cmd copies this file to .env.
# Plan-only is the built-in default. Uncomment to make it explicit.
# CA_RUN_MODE=plan_only
CA_CONSOLE_PORT=8765
CA_CONSOLE_OPEN_BROWSER=true
# The native default is loopback. Docker supplies 0.0.0.0 only inside its host-loopback mapping.
# CA_CONSOLE_BIND_HOST=127.0.0.1

# Native development can point at any approved, reachable Ollama service. Compose overrides this
# value with its internal service URL, so it never depends on a host-installed Ollama process.
CA_OLLAMA_BASE_URL=http://localhost:11434/v1
CA_OLLAMA_MODEL=gemma4:12b
CA_LLM_REQUEST_TIMEOUT_SECONDS=120
CA_GROUP_CHAT_TIMEOUT_SECONDS=300
# Use a different reachable vision-capable model for native attended-browser development if needed.
CA_BROWSER_MODEL=gemma4:12b
CA_PERSONA_TEMPERATURE=1.25
CA_GROUP_CHAT_MAX_ROUNDS=8
CA_BROWSER_AGENT_MAX_STEPS=40
CA_BROWSER_CANDIDATE_LIMIT=80
CA_BROWSER_LOGIN_TIMEOUT_SECONDS=900
CA_GMAIL_COMPLIANCE_URL=https://admin.google.com/ac/apps/gmail/compliance

# Dry-run and live browser modes require these exact identity expectations.
# CA_EXPECTED_ADMIN_EMAIL=admin@example.com
# CA_EXPECTED_WORKSPACE_DOMAIN=example.com
